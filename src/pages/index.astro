---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const title = "翻茄笔记 - 专注技术与生活的原创博客";
const description = "翻茄笔记，为您精选和创作高质量的网络技术科普、工具使用教程与生活思考。";
const keywords = "翻茄笔记, 原创博客, 机场推荐, VPN科普, 技术教程";

const allArticles = await getCollection('articles');
// 排序：有日期的按日期排，没日期的排在后面
const sortedArticles = allArticles.sort((a, b) => {
    const dateA = new Date(a.data.pubDate || '2000-01-01').getTime();
    const dateB = new Date(b.data.pubDate || '2000-01-01').getTime();
    return dateB - dateA;
});
---
<BaseLayout title={title} description={description} keywords={keywords}>
    
    <!-- Blog Hero Section -->
    <section class="hero">
        <div class="container">
            <h1 class="hero-title">探索代码与生活的边界</h1>
            <p class="hero-subtitle">在这里，我们分享前沿的网络技术科普、实用的工具指南，以及关于数字生活的深度思考。每天进步一点点。</p>
        </div>
    </section>

    <!-- Blog Articles Grid -->
    <section class="section-padding" style="padding-top: 0;">
        <div class="container">
            <div class="blog-grid">
                {sortedArticles.map((article) => {
                    const pubDate = article.data.pubDate ? new Date(article.data.pubDate).toISOString().split('T')[0] : '精选文章';
                    return (
                        <a href={`/${article.id}.html`} class="blog-card">
                            <div class="blog-meta">
                                <span class="text-accent">●</span> {pubDate}
                            </div>
                            <h3>{article.data.title}</h3>
                            <p>{article.data.description}</p>
                        </a>
                    )
                })}
            </div>
        </div>
    </section>

</BaseLayout>
