---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = "网址导航 - 出海工具与常用网站推荐 | 翻翻节点";
const description = "翻翻节点网址导航，出海工具推荐网站。涵盖AI工具、流媒体、社交媒体、电子邮件、在线工具及网络监控。一站式解决你的出海难题。";
const keywords = "网址导航, AI工具, 翻墙工具, 出海工具, 流媒体解锁";
---
<BaseLayout title={title} description={description} keywords={keywords}>
<div class="nav-page-hero">
        <div class="container">
            <h1 class="nav-page-title">🌐 出海网址导航</h1>
            <p class="nav-page-desc">涵盖AI工具、流媒体、社交媒体、常用在线工具。一站式解决你的出海需求。</p>
        </div>
    </div>

    <div class="container" style="min-height: 60vh;">
        
        <!-- AI -->
        <section class="nav-section" id="ai">
            <h2 class="nav-section-title">🤖 AI 工具</h2>
            <div class="nav-grid">
                <a href="https://chatgpt.com/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon">✨</div>
                    <div class="nav-info">
                        <span class="nav-name">ChatGPT</span>
                        <span class="nav-desc">OpenAI 的人工智能聊天机器人程序。</span>
                    </div>
                </a>
                <a href="https://chat.deepseek.com/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon">🐋</div>
                    <div class="nav-info">
                        <span class="nav-name">DeepSeek</span>
                        <span class="nav-desc">深度求索的人工智能大型语言模型。</span>
                    </div>
                </a>
                <a href="https://gemini.google.com/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon">✨</div>
                    <div class="nav-info">
                        <span class="nav-name">Gemini</span>
                        <span class="nav-desc">Google 的生成式人工智能聊天机器人。</span>
                    </div>
                </a>
                <a href="https://grok.com/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon">❌</div>
                    <div class="nav-info">
                        <span class="nav-name">Grok</span>
                        <span class="nav-desc">xAI 的生成式人工智能聊天机器人。</span>
                    </div>
                </a>
                <a href="https://claude.ai/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon">🧠</div>
                    <div class="nav-info">
                        <span class="nav-name">Claude</span>
                        <span class="nav-desc">Anthropic 的大型语言模型。</span>
                    </div>
                </a>
            </div>
        </section>

        <!-- 流媒体 -->
        <section class="nav-section" id="streaming">
            <h2 class="nav-section-title">📺 流媒体</h2>
            <div class="nav-grid">
                <a href="https://www.youtube.com/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon" style="color: #ff0000;">▶️</div>
                    <div class="nav-info">
                        <span class="nav-name">YouTube</span>
                        <span class="nav-desc">全球最大的视频搜索和分享平台。</span>
                    </div>
                </a>
                <a href="https://www.netflix.com/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon" style="color: #E50914;">N</div>
                    <div class="nav-info">
                        <span class="nav-name">Netflix</span>
                        <span class="nav-desc">网络视频点播的 OTT 服务网站。</span>
                    </div>
                </a>
                <a href="https://www.disneyplus.com/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon" style="color: #113CCF;">D+</div>
                    <div class="nav-info">
                        <span class="nav-name">Disney+</span>
                        <span class="nav-desc">迪士尼的在线流媒体视频点播平台。</span>
                    </div>
                </a>
                <a href="https://www.primevideo.com/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon" style="color: #00A8E1;">P</div>
                    <div class="nav-info">
                        <span class="nav-name">Prime Video</span>
                        <span class="nav-desc">亚马逊的互联网视频点播服务。</span>
                    </div>
                </a>
                <a href="https://www.hulu.com/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon" style="color: #1CE783;">H</div>
                    <div class="nav-info">
                        <span class="nav-name">Hulu</span>
                        <span class="nav-desc">网络付费随选流影片及影视节目的 OTT 服务。</span>
                    </div>
                </a>
            </div>
        </section>

        <!-- 社交媒体 -->
        <section class="nav-section" id="social">
            <h2 class="nav-section-title">📱 社交媒体</h2>
            <div class="nav-grid">
                <a href="https://www.instagram.com/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon" style="color: #E1306C;">📷</div>
                    <div class="nav-info">
                        <span class="nav-name">Instagram</span>
                        <span class="nav-desc">在线图片及视频分享的社群应用程序。</span>
                    </div>
                </a>
                <a href="https://x.com/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon">𝕏</div>
                    <div class="nav-info">
                        <span class="nav-name">X (Twitter)</span>
                        <span class="nav-desc">全球顶尖的社交媒体平台之一。</span>
                    </div>
                </a>
                <a href="https://www.reddit.com/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon" style="color: #FF4500;">👽</div>
                    <div class="nav-info">
                        <span class="nav-name">Reddit</span>
                        <span class="nav-desc">娱乐、社交及新闻网站。</span>
                    </div>
                </a>
                <a href="https://web.telegram.org/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon" style="color: #0088cc;">✈️</div>
                    <div class="nav-info">
                        <span class="nav-name">Telegram</span>
                        <span class="nav-desc">跨平台的即时通信软件。</span>
                    </div>
                </a>
            </div>
        </section>

        <!-- 电子邮件 -->
        <section class="nav-section" id="email">
            <h2 class="nav-section-title">📧 电子邮件</h2>
            <div class="nav-grid">
                <a href="https://outlook.live.com/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon" style="color: #0078D4;">✉️</div>
                    <div class="nav-info">
                        <span class="nav-name">Outlook</span>
                        <span class="nav-desc">微软的免费互联网收发电子邮件服务。</span>
                    </div>
                </a>
                <a href="https://gmail.google.com/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon" style="color: #D44638;">M</div>
                    <div class="nav-info">
                        <span class="nav-name">Gmail</span>
                        <span class="nav-desc">Google 的免费电子邮件服务。</span>
                    </div>
                </a>
                <a href="https://mail.proton.me/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon" style="color: #6D4AFF;">🔒</div>
                    <div class="nav-info">
                        <span class="nav-name">Proton Mail</span>
                        <span class="nav-desc">端到端加密的电子邮件服务。</span>
                    </div>
                </a>
                <a href="https://temp-mail.org/zh/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon">⏱️</div>
                    <div class="nav-info">
                        <span class="nav-name">Temp Mail</span>
                        <span class="nav-desc">匿名的一次性电子邮件。</span>
                    </div>
                </a>
            </div>
        </section>

        <!-- 在线工具 -->
        <section class="nav-section" id="tools">
            <h2 class="nav-section-title">🛠️ 在线工具</h2>
            <div class="nav-grid">
                <a href="https://telegra.ph/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon">📝</div>
                    <div class="nav-info">
                        <span class="nav-name">Telegraph</span>
                        <span class="nav-desc">Telegram 的内容发布网站。</span>
                    </div>
                </a>
                <a href="https://reurl.cc/main/cn" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon">🔗</div>
                    <div class="nav-info">
                        <span class="nav-name">Reurl</span>
                        <span class="nav-desc">短链接在线生成。</span>
                    </div>
                </a>
                <a href="https://sub-web.netlify.app/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon">🔄</div>
                    <div class="nav-info">
                        <span class="nav-name">Subscription Converter</span>
                        <span class="nav-desc">各种订阅链接生成。</span>
                    </div>
                </a>
            </div>
        </section>

        <!-- 网络监控 -->
        <section class="nav-section" id="network">
            <h2 class="nav-section-title">📡 网络监控</h2>
            <div class="nav-grid">
                <a href="https://fast.com/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon" style="color: #E50914;">⚡</div>
                    <div class="nav-info">
                        <span class="nav-name">Fast</span>
                        <span class="nav-desc">奈飞的简单网速测试。</span>
                    </div>
                </a>
                <a href="https://whoer.net/zh" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon">🕵️</div>
                    <div class="nav-info">
                        <span class="nav-name">Whoer</span>
                        <span class="nav-desc">IP 伪装度检测。</span>
                    </div>
                </a>
                <a href="https://ping0.cc/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon">💧</div>
                    <div class="nav-info">
                        <span class="nav-name">PING0</span>
                        <span class="nav-desc">IP 纯净度检测。</span>
                    </div>
                </a>
                <a href="https://browserleaks.com/dns" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon">🛡️</div>
                    <div class="nav-info">
                        <span class="nav-name">BrowserLeaks</span>
                        <span class="nav-desc">DNS 泄露检测。</span>
                    </div>
                </a>
                <a href="https://ipcheck.ing/" target="_blank" rel="nofollow" class="nav-card">
                    <div class="nav-icon">🔍</div>
                    <div class="nav-info">
                        <span class="nav-name">IPCheck</span>
                        <span class="nav-desc">好用和开源的全能 IP 工具箱。</span>
                    </div>
                </a>
            </div>
        </section>

    </div>
</BaseLayout>
