---
const { title, description, keywords } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title || '翻茄笔记 - 2026 稳定高速机场推荐与使用教程 | 专注科学上网科普'}</title>
