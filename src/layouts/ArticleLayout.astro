---
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props;
const title = frontmatter?.title || Astro.props.title || '';
const description = frontmatter?.description || Astro.props.description || '';
const keywords = frontmatter?.keywords || Astro.props.keywords || '';
const subtitle = frontmatter?.subtitle || Astro.props.subtitle || '';
---
<BaseLayout title={title} description={description} keywords={keywords}>
    <!-- Mini Hero -->
    <section class="hero" style="padding: 180px 0 80px; text-align: center; background: linear-gradient(180deg, #D4EBF8 0%, var(--bg-color) 100%);">
        <div class="hero-clouds">
            <div class="cloud cloud-1"></div>
            <div class="cloud cloud-2"></div>
        </div>
        <div class="container relative" style="z-index: 2;">
            <h1 class="hero-title" style="margin-bottom:15px;">{title}</h1>
            {subtitle && <p class="hero-subtitle" style="margin-bottom:0;">{subtitle}</p>}
        </div>
        <div class="hero-grass"></div>
    </section>
    
    <section class="article-page section-padding">
        <div class="container" style="max-width: 900px; margin: 0 auto; background: #fff; padding: 50px 60px; border-radius: 20px; border: 2px solid var(--border-color); box-shadow: var(--shadow);">
            <div class="article-body">
                <slot />
            </div>
        </div>
    </section>
</BaseLayout>
