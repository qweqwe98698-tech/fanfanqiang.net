---
const { title, description, keywords } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title || '翻茄笔记 - 原创技术与生活博客'}</title>
    <meta name="description" content={description || '翻茄笔记，记录技术、生活与思考的原创个人博客。'}>
    <meta name="keywords" content={keywords || '翻茄笔记, 个人博客, 技术博客, 原创文章'}>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🍅</text></svg>">
    
    <!-- PWA Support -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#FF5E3A">
    <link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🍅</text></svg>">
    
    <link rel="stylesheet" href="/style.css">

    <!-- SEO & Social Meta Tags -->
    <link rel="canonical" href={Astro.url} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title || '翻茄笔记'} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:site_name" content="翻茄笔记" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title || '翻茄笔记'} />
    <meta name="twitter:description" content={description} />
</head>
<body>

    <!-- Header -->
    <header class="navbar">
        <div class="container nav-container">
            <a href="/" class="logo">
                <span class="logo-icon">🍅</span>
                翻茄笔记
            </a>
            <nav class="nav-links">
                <a href="/">全部文章</a>
                <a href="/airports.html">✈️ 机场推荐</a>
                <a href="/article-client-tutorials.html">📖 使用教程</a>
                <a href="/nav.html">🌐 网址导航</a>
            </nav>
        </div>
    </header>

    <!-- Main Content -->
    <slot />

    <!-- Footer -->
    <footer class="footer">
        <div class="container footer-container">
            <div class="footer-brand">
                <h2>🍅 翻茄笔记</h2>
                <p>探索技术与生活的无限可能。专注原创内容的创作与分享，让每一次阅读都有所收获。</p>
            </div>
            <div class="footer-links">
                <h4>导航</h4>
                <ul>
                    <li><a href="/">最新文章</a></li>
                    <li><a href="/airports.html">精选机场推荐</a></li>
                    <li><a href="/article-client-tutorials.html">工具配置指南</a></li>
                    <li><a href="/nav.html">网址导航</a></li>
                </ul>
            </div>
            <div class="footer-links">
                <h4>友情链接</h4>
                <ul>
                    <li><a href="https://vpnsgocn.com/" target="_blank" rel="dofollow noopener">VPN风暴云</a></li>
                    <li><a href="https://clashvpns.cloud/" target="_blank" rel="dofollow noopener">柳如烟</a></li>
                </ul>
            </div>
        </div>
        <div class="container footer-bottom">
            <p>&copy; 2026 fanfanqiang.net 翻茄笔记. All Rights Reserved. Crafted with passion.</p>
        </div>
    </footer>

    <script is:inline src="/script.js"></script>
    <script is:inline>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').then(registration => {
                    console.log('SW registered: ', registration);
                }).catch(registrationError => {
                    console.log('SW registration failed: ', registrationError);
                });
            });
        }
    </script>
</body>
</html>
